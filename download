// ===== 取込履歴 =====
router.get('/imports', (req, res) => {
  const rows = db.prepare(`
    SELECT * FROM import_logs ORDER BY created_at DESC LIMIT 100
  `).all();
  res.json({ data: rows });
});

module.exports = router;
