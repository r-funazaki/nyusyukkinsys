  const today = new Date().toISOString().slice(0, 10);
  const rows = [
    ['取扱日', '氏名カナ', '氏名漢字', '金額', '口座番号', 'コマーシャル', '発送種別'],
    [today, 'ヤマダ タロウ', '山田 太郎', '15000', '00120-1-234567', '会員番号:A1024', '一般'],
    [today, 'サトウ ハナコ', '佐藤 花子', '8000', '00120-1-234567', '会員番号:A2048', '速達'],
    [today, 'タナカ ジロウ', '田中 次郎', '25000', '00120-1-234567', '会員番号:A1099', '書留']
